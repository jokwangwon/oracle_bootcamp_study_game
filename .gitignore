# OSS 모델 평가 — GGUF 가중치 (SDD v2 §8, ~34GB)
# Modelfile과 README는 커밋, 가중치/검증 임시 파일만 제외
apps/api/src/modules/ai/eval/modelfiles/*.gguf
apps/api/src/modules/ai/eval/modelfiles/*.gguf.sha256
apps/api/src/modules/ai/eval/modelfiles/*.gguf.sha256.expected

