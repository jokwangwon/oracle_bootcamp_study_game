# PR-13 (consensus-013, ADR-021) — Playwright e2e dummy 환경변수.
#
# SDD §4.5: dummy 값만. 실 secret 은 GitHub Actions secrets / 사용자 노트북의
# .env.test.local (gitignored) 에서 override.
#
# docker-compose.test.yml 의 ${VAR:-default} 패턴이 본 파일의 값을 우선 사용.

TEST_DB_PASSWORD=test_only_dummy_password
TEST_JWT_SECRET=test_only_jwt_secret_dummy_for_e2e_min_32chars_xx
TEST_JWT_REFRESH_SECRET=test_only_refresh_secret_dummy_for_e2e_min_32chars
TEST_HASH_SALT=test_only_hash_salt_dummy_min_16

E2E_BASE_URL=http://localhost:3001
