# PR-13 Phase 1A — e2e dummy 환경변수 (SDD §4.5).
#
# - 모든 secret 은 dummy. 실 운영 값과 분리. gitleaks scan 통과 위해 placeholder pattern 사용.
# - test-db (port 5433) / test-redis (port 6380) — 운영 5432 / 6379 와 분리 (SDD §4.1).
# - LANGFUSE_DISABLED=1 — observability trace queue 누수 차단 (SDD §4.3).

NODE_ENV=test
PORT=3002

# DB schema 격리 — apps/e2e/docker-compose.test.yml 의 test-db (port 5435)
# 5433 은 ai-bench-db 점유 → 5435 로 분리
DATABASE_URL=postgres://test_user:test_only_dummy_password@localhost:5435/bootcamp_test
REDIS_URL=redis://localhost:6380

# JWT — env.validation refinement: JWT_SECRET / JWT_REFRESH_SECRET / USER_TOKEN_HASH_SALT 모두 서로 달라야 함
JWT_SECRET=test_only_jwt_secret_dummy_for_e2e_min_32chars_xx
JWT_REFRESH_SECRET=test_only_refresh_secret_dummy_for_e2e_min_32chars
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=14d

# USER_TOKEN_HASH_SALT — 16자 이상, JWT 와 다른 값
USER_TOKEN_HASH_SALT=test_only_hash_salt_dummy_min_16

# Langfuse — disabled fallback (SDD §4.3)
LANGFUSE_PUBLIC_KEY=disabled-e2e-only
LANGFUSE_SECRET_KEY=disabled-e2e-only
LANGFUSE_HOST=http://localhost:3010
LANGFUSE_DISABLED=1

# OriginGuard — test-web 만 허용
CORS_ORIGIN=http://localhost:3001
# e2e 의 supertest 는 Origin 헤더 미전송이 default → enforce 시 모든 요청 403.
# OriginGuard 자체 회귀는 별도 origin.guard.test.ts (단위 테스트 38 cases) 가 검증.
# 본 e2e 는 비즈니스 로직 회귀 (auth/discussion) 가 핵심이므로 report 모드로 우회.
ORIGIN_GUARD_MODE=report

# LLM — anthropic 분기 (실 호출 없음, e2e 에서는 ENABLE_FREE_FORM_GRADING=false)
LLM_PROVIDER=anthropic
LLM_API_KEY=disabled-e2e-only
LLM_MODEL=claude-opus-4-6
OLLAMA_BASE_URL=http://localhost:11434

# 게임/채점 kill-switch — e2e 에서는 LLM 경로 비활성
ENABLE_FREE_FORM_GRADING=false
SEED_ON_BOOT=false

# PR-13 — Throttler 우회 (e2e 다수 register/login 시도 시 429 차단 회피).
# Throttler 회귀는 단위 테스트가 검증.
THROTTLE_DISABLED=1
