{
  "name": "@oracle-game/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "validate:free-form-seeds": "tsx src/scripts/validate-free-form-seeds.ts",
    "ops:rotate-salt": "tsx src/scripts/rotate-salt.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- -d src/config/data-source.ts migration:generate",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:run": "npm run typeorm -- -d src/config/data-source.ts migration:run",
    "migration:revert": "npm run typeorm -- -d src/config/data-source.ts migration:revert",
    "migration:show": "npm run typeorm -- -d src/config/data-source.ts migration:show"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.7",
    "@langchain/core": "^0.3.18",
    "@langchain/ollama": "^0.2.4",
    "@nestjs/bullmq": "^10.1.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.3.0",
    "@notionhq/client": "^5.18.0",
    "@oracle-game/shared": "*",
    "@types/cookie-parser": "^1.4.10",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "helmet": "^7.2.0",
    "ioredis": "^5.4.0",
    "langchain": "^0.3.5",
    "langfuse": "^3.27.0",
    "langfuse-langchain": "^3.27.0",
    "node-sql-parser": "^5.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "typeorm": "^0.3.20",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.1",
    "promptfoo": "^0.121.3",
    "supertest": "^7.2.2",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
